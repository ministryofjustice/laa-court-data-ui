- content_for :page_title, "#{t('.title')} - #{service_name} - GOV.UK"
- content_for :page_heading do
  %h1.govuk-heading-xl{ class: "govuk-!-margin-bottom-5" }
    = t(".title")
%strong.govuk-tag{ class: "govuk-!-margin-bottom-5" }
  = t("generic.case")

.govuk-grid-row
  .govuk-grid-column-two-thirds
    %table.govuk-table
      %caption.govuk-table__caption.govuk-visually-hidden
        = t(".title")
      %tbody.govuk-table__body
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".name")
          %td.govuk-table__cell
            = @defendant.name
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".date_of_birth")
          %td.govuk-table__cell
            = l(@defendant.date_of_birth&.to_date, format: :medium)
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".case_urn")
          %td.govuk-table__cell
            = @prosecution_case_reference
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".arrest_summons_number")
          %td.govuk-table__cell
            = @defendant.arrest_summons_number
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".maat_number")
          %td.govuk-table__cell
            = @defendant.maat_reference

= form_with(model: @form_model, url: unlink_defendant_path(@defendant.id, urn: @prosecution_case_reference), data: { turbo: false }) do |f|
  - content_for :error_summary do
    = f.govuk_error_summary

  .govuk-grid-row
    .govuk-grid-column-two-thirds
      - unlink_reasons = UnlinkReason.all
      = f.govuk_radio_buttons_fieldset :reason_code, small: true, legend: { text: t('defendants.form.reason_code.label') } do
        - unlink_reasons.each do |reason|
          - if reason.text_required?
            = f.govuk_radio_button :reason_code, reason.code, label: { text: reason.description } do
              = f.govuk_text_area :other_reason_text,
                                  label: { text: t('defendants.form.other_reason_text.label') },
                                  rows: 5,
                                  max_chars: 500
          - else
            = f.govuk_radio_button :reason_code, reason.code, label: { text: reason.description }

      .govuk-inset-text
        = t('defendants.unlink.warning')

      .govuk-button-group
        = f.govuk_submit t('.submit'), data: { disable_with: t('defendants.form.unlinking') }, class: 'govuk-button--warning'
        = link_to t('.back'), defendant_path(@defendant.id, urn: @prosecution_case_reference), class: 'govuk-link'
