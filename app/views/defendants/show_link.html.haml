- content_for :page_title, "#{t('.title')} - #{service_name} - GOV.UK"
- content_for :page_heading do
  %h1.govuk-heading-xl{ class: "govuk-!-margin-bottom-5" }
    = t(".title")
%strong.govuk-tag{ class: "govuk-!-margin-bottom-5" }
  = t("generic.case")

.govuk-grid-row
  .govuk-grid-column-two-thirds
    %table.govuk-table
      %caption.govuk-table__caption.govuk-visually-hidden
        = t(".title")
      %tbody.govuk-table__body
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".name")
          %td.govuk-table__cell
            = @defendant.name
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".date_of_birth")
          %td.govuk-table__cell
            = l(@defendant.date_of_birth&.to_date, format: :medium)
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".case_urn")
          %td.govuk-table__cell
            = @prosecution_case_reference
        %tr.govuk-table__row
          %th.govuk-table__header{ scope: "row" }
            = t(".arrest_summons_number")
          %td.govuk-table__cell
            = @defendant.arrest_summons_number

= form_with(model: @form_model, url: link_defendant_path(@defendant.id, urn: @prosecution_case_reference), data: { turbo: false }) do |f|
  - content_for :error_summary do
    = f.govuk_error_summary

  .govuk-grid-row
    .govuk-grid-column-two-thirds
      = f.govuk_text_field :maat_reference,
                           label: { text: t('laa_reference.link.form.maat_reference.label') },
                           hint: { text: t('laa_reference.link.form.maat_reference.hint') }

      .govuk-button-group
        = f.govuk_submit t('laa_reference.link.form.submit'), data: { disable_with: 'Linking...' }, name: 'maat_ref_required', value: 'true'
        = link_to t('.back'), defendant_path(@defendant.id, urn: @prosecution_case_reference), class: 'govuk-link'

      = govuk_detail(t('laa_reference.missing_maat_id.label')) do
        %p.govuk-details__details-text= t('laa_reference.missing_maat_id.description')
        = f.govuk_submit(t('laa_reference.missing_maat_id.submit'), secondary: true, name: 'maat_ref_required', value: 'false')
