%table.govuk-table{ class: "govuk-!-margin-bottom-4" }
  %caption.govuk-table__caption.govuk-visually-hidden
    = t('search.result.defendant.caption')
  %tbody.govuk-table__body
    %tr.govuk-table__row
      %th.govuk-table__header{ scope: 'row' }
        = t('search.result.defendant.date_of_birth')
      %td.govuk-table__cell
        %span#defendant-dob= l(defendant.date_of_birth&.to_date)
      %td.govuk-table__cell{ class: "govuk-!-text-align-right" }
        - if defendant.date_of_birth.present?
          %button.govuk-button.govuk-button--secondary.copy-button{ id: "copy-dob", type: "button", class: "govuk-!-margin-bottom-0" }
            Copy
    %tr.govuk-table__row
      %th.govuk-table__header{ scope: 'row' }
        = t('search.result.defendant.prosecution_case_reference')
      %td.govuk-table__cell
        %span#defendant-case-urn= prosecution_case_reference
      %td.govuk-table__cell{ class: "govuk-!-text-align-right" }
        %button.govuk-button.govuk-button--secondary.copy-button{ id: "copy-case-urn", type: "button", class: "govuk-!-margin-bottom-0" }
          Copy
    %tr.govuk-table__row
      %th.govuk-table__header{ scope: 'row' }
        = t('search.result.defendant.arrest_summons_number')
      %td.govuk-table__cell
        %span#defendant-asn= defendant.arrest_summons_number
      %td.govuk-table__cell{ class: "govuk-!-text-align-right" }
        - if defendant.arrest_summons_number.present?
          %button.govuk-button.govuk-button--secondary.copy-button{ id: "copy-asn", type: "button", class: "govuk-!-margin-bottom-0" }
            Copy
    %tr.govuk-table__row
      %th.govuk-table__header{ scope: 'row' }
        = t('search.result.defendant.maat_number')
      %td.govuk-table__cell
        - if defendant.maat_reference.present?
          %span#defendant-maat-number= defendant.maat_reference
          - if linking_enabled?
            = link_to 'Unlink MAAT ID', unlink_defendant_path(defendant.id, urn: prosecution_case_reference), class: 'govuk-link govuk-!-margin-left-4'
        - else
          Not linked
      %td.govuk-table__cell{ class: "govuk-!-text-align-right" }
        - if defendant.maat_reference.present?
          %button.govuk-button.govuk-button--secondary.copy-button{ id: "copy-maat-number", type: "button", class: "govuk-!-margin-bottom-0" }
            Copy
        - elsif linking_enabled?
          = link_to 'Link MAAT ID', link_defendant_path(defendant.id, urn: prosecution_case_reference), class: 'govuk-link'

= link_to 'View case summary', prosecution_case_path(prosecution_case_reference), class: 'govuk-button govuk-button--secondary govuk-!-margin-bottom-9'
